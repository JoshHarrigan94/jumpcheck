/* =========================================================
GRAPH RENDERING
========================================================= */

function drawJumpGraph(analysis){

  const canvas = ui.jumpGraph;
  const ctx = canvas.getContext("2d");

  const width = canvas.width;
  const height = canvas.height;

  ctx.clearRect(0,0,width,height);

  ctx.fillStyle = "rgba(0,0,0,.18)";
  ctx.fillRect(0,0,width,height);

  if(!analysis || !analysis.samples || analysis.samples.length < 2){
    return;
  }

  const values =
    analysis.smooth && analysis.smooth.length
      ? analysis.smooth
      : analysis.samples.map(sample => sample.magnitude);

  const minValue = Math.min(...values, 0);
  const maxValue = Math.max(...values, (state.baseline || G) * 2.6);

  const padding = 20;

  function xFor(index){
    return padding + (index / (values.length - 1)) * (width - padding * 2);
  }

  function yFor(value){
    return height - padding - ((value - minValue) / (maxValue - minValue || 1)) * (height - padding * 2);
  }

  ctx.strokeStyle = "rgba(255,255,255,.10)";
  ctx.lineWidth = 1;

  for(let i = 0; i < 4; i++){
    const y = padding + i * ((height - padding * 2) / 3);
    ctx.beginPath();
    ctx.moveTo(padding,y);
    ctx.lineTo(width - padding,y);
    ctx.stroke();
  }

  if(state.baseline){

    ctx.strokeStyle = "rgba(124,199,255,.55)";
    ctx.setLineDash([6,6]);

    const baselineY = yFor(state.baseline);

    ctx.beginPath();
    ctx.moveTo(padding,baselineY);
    ctx.lineTo(width - padding,baselineY);
    ctx.stroke();

    ctx.setLineDash([]);

  }

  ctx.strokeStyle = "rgba(255,255,255,.92)";
  ctx.lineWidth = 2;

  ctx.beginPath();

  values.forEach((value,index) => {

    const x = xFor(index);
    const y = yFor(value);

    if(index === 0){
      ctx.moveTo(x,y);
    }else{
      ctx.lineTo(x,y);
    }

  });

  ctx.stroke();

  if(analysis.takeoffIndex >= 0){

    const x = xFor(analysis.takeoffIndex);

    ctx.strokeStyle = "#37d67a";
    ctx.lineWidth = 2;

    ctx.beginPath();
    ctx.moveTo(x,padding);
    ctx.lineTo(x,height - padding);
    ctx.stroke();

    ctx.fillStyle = "#37d67a";
    ctx.font = "12px system-ui";
    ctx.fillText("take-off", x + 4, 18);

  }

  if(analysis.landingIndex >= 0){

    const x = xFor(analysis.landingIndex);

    ctx.strokeStyle = "#ff5f7a";
    ctx.lineWidth = 2;

    ctx.beginPath();
    ctx.moveTo(x,padding);
    ctx.lineTo(x,height - padding);
    ctx.stroke();

    ctx.fillStyle = "#ff5f7a";
    ctx.font = "12px system-ui";
    ctx.fillText("landing", x + 4, 36);

  }

}

/* =========================================================
SAVE SESSION
========================================================= */

function saveSession(){

  const summary = calculateAssessmentSummary();

  if(!summary){

    setStatus(
      ui.testStatus,
      "No valid assessment to save yet.",
      "warn"
    );

    return;

  }

  const session = {
    id:String(Date.now()),
    date:new Date().toISOString(),
    type:ui.testType.value,
    notes:ui.sessionNotes.value.trim(),
    jumps:summary.heights.map(value => Number(value.toFixed(2))),
    best:Number(summary.best.toFixed(2)),
    average:Number(summary.average.toFixed(2)),
    dropoff:Number(summary.dropoff.toFixed(2)),
    baseline:Number((state.baseline || G).toFixed(3))
  };

  state.history.unshift(session);

  saveHistory();

  renderHistory();

  setStatus(
    ui.testStatus,
    "Session saved on this device.",
    "good"
  );

}

/* =========================================================
HISTORY RENDERING
========================================================= */

function escapeHTML(value){

  return String(value)
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#039;");

}

function renderHistory(){

  if(!state.history.length){

    ui.historyList.innerHTML =
      `<div class="status">No saved sessions yet.</div>`;

    return;

  }

  ui.historyList.innerHTML =
    state.history.map(session => {

      const date =
        new Date(session.date).toLocaleString();

      const jumps =
        session.jumps
          .map((jump,index) => {
            return `
              <span class="pill">
                J${index + 1}: ${formatNumber(jump,1)} cm
              </span>
            `;
          })
          .join("");

      return `
        <div class="historyItem">

          <div class="grid2">

            <div>
              <strong>${escapeHTML(date)}</strong>
              <div class="resultSub">
                ${escapeHTML(session.type)}
              </div>
            </div>

            <div style="text-align:right;">
              <div class="metricValue">
                ${formatNumber(session.best,1)} cm
              </div>
              <div class="resultSub">
                avg ${formatNumber(session.average,1)} /
                drop ${formatNumber(session.dropoff,1)}%
              </div>
            </div>

          </div>

          <div class="pills">
            ${jumps}
          </div>

          ${
            session.notes
              ? `<div class="resultSub">${escapeHTML(session.notes)}</div>`
              : ""
          }

        </div>
      `;

    }).join("");

}

/* =========================================================
EXPORT CSV
========================================================= */

function exportCsv(){

  if(!state.history.length){

    setStatus(
      ui.testStatus,
      "No history to export yet.",
      "warn"
    );

    return;

  }

  const headers = [
    "date",
    "type",
    "jump_1_cm",
    "jump_2_cm",
    "jump_3_cm",
    "best_cm",
    "average_cm",
    "dropoff_percent",
    "baseline",
    "notes"
  ];

  const rows =
    state.history.map(session => {

      const safeNotes =
        `"${String(session.notes || "").replaceAll('"','""')}"`;

      return [
        session.date,
        session.type,
        session.jumps[0] || "",
        session.jumps[1] || "",
        session.jumps[2] || "",
        session.best,
        session.average,
        session.dropoff,
        session.baseline,
        safeNotes
      ].join(",");

    });

  const csv =
    [headers.join(","), ...rows].join("\n");

  const blob =
    new Blob([csv], {type:"text/csv"});

  const url =
    URL.createObjectURL(blob);

  const link =
    document.createElement("a");

  link.href = url;
  link.download = "jumpcheck-v2-history.csv";

  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);

  URL.revokeObjectURL(url);

}

/* =========================================================
CLEAR HISTORY
========================================================= */

function clearHistory(){

  const confirmDelete =
    confirm("Delete all JumpCheck history on this device?");

  if(!confirmDelete){
    return;
  }

  state.history = [];

  saveHistory();

  renderHistory();

  setStatus(
    ui.testStatus,
    "History cleared.",
    "warn"
  );

}

/* =========================================================
FINAL EVENT LISTENERS
========================================================= */

ui.saveSessionBtn.addEventListener(
  "click",
  saveSession
);

ui.exportCsvBtn.addEventListener(
  "click",
  exportCsv
);

ui.clearHistoryBtn.addEventListener(
  "click",
  clearHistory
);

/* =========================================================
INITIALISE APP
========================================================= */

renderHistory();

drawJumpGraph(null);

})();

