<script>

(() => {

"use strict";

/* =========================================================
CONSTANTS
========================================================= */

const G = 9.80665;

const STORAGE_KEY = "jumpcheck_v2_history";

/* =========================================================
APP STATE
========================================================= */

const state = {

  motionEnabled:false,

  demoMode:false,

  recording:false,

  calibrating:false,

  assessmentRunning:false,

  live:{
    x:0,
    y:0,
    z:0,
    magnitude:0
  },

  sampleRate:0,

  lastSampleTime:null,

  baseline:null,

  samples:[],

  attempts:[],

  currentAttempt:0,

  latestAnalysis:null,

  history:loadHistory()

};

/* =========================================================
ELEMENT SHORTCUT
========================================================= */

function $(id){
  return document.getElementById(id);
}

/* =========================================================
DOM REFERENCES
========================================================= */

const ui = {

  permissionStatus:$("permissionStatus"),

  enableMotionBtn:$("enableMotionBtn"),
  demoModeBtn:$("demoModeBtn"),

  liveX:$("liveX"),
  liveY:$("liveY"),
  liveZ:$("liveZ"),
  liveMagnitude:$("liveMagnitude"),
  sampleRate:$("sampleRate"),

  testType:$("testType"),
  sessionNotes:$("sessionNotes"),

  calibrateBtn:$("calibrateBtn"),
  startAssessmentBtn:$("startAssessmentBtn"),

  testStatus:$("testStatus"),

  countdown:$("countdown"),

  baselineValue:$("baselineValue"),
  attemptCounter:$("attemptCounter"),

  jumpGraph:$("jumpGraph"),

  resultsCard:$("resultsCard"),

  bestJumpValue:$("bestJumpValue"),
  confidencePill:$("confidencePill"),
  readinessPill:$("readinessPill"),

  bestMetric:$("bestMetric"),
  averageMetric:$("averageMetric"),
  dropoffMetric:$("dropoffMetric"),

  attemptPills:$("attemptPills"),

  saveSessionBtn:$("saveSessionBtn"),

  exportCsvBtn:$("exportCsvBtn"),
  clearHistoryBtn:$("clearHistoryBtn"),

  historyList:$("historyList")

};

/* =========================================================
UTILITY HELPERS
========================================================= */

function formatNumber(value, decimals = 1){

  if(!Number.isFinite(value)){
    return "--";
  }

  return value.toFixed(decimals);

}

function setStatus(element, message, type = ""){

  element.className = "status";

  if(type){
    element.classList.add(type);
  }

  element.textContent = message;

}

function setPill(element, message, type = ""){

  element.className = "pill";

  if(type){
    element.classList.add(type);
  }

  element.textContent = message;

}

function sleep(ms){

  return new Promise(resolve => setTimeout(resolve, ms));

}

function loadHistory(){

  try{

    const raw = localStorage.getItem(STORAGE_KEY);

    if(!raw){
      return [];
    }

    return JSON.parse(raw);

  }catch(error){

    return [];

  }

}

function saveHistory(){

  localStorage.setItem(
    STORAGE_KEY,
    JSON.stringify(state.history)
  );

}

/* =========================================================
MOTION PERMISSION
========================================================= */

async function enableMotionSensors(){

  try{

    if(!window.DeviceMotionEvent){

      setStatus(
        ui.permissionStatus,
        "DeviceMotionEvent is not available in this browser. Try Safari or Chrome on your phone.",
        "bad"
      );

      return;

    }

    /*
      iOS requires explicit permission from a user gesture.
      Android usually allows this without requestPermission.
    */

    if(typeof DeviceMotionEvent.requestPermission === "function"){

      const response =
        await DeviceMotionEvent.requestPermission();

      if(response !== "granted"){

        setStatus(
          ui.permissionStatus,
          "Motion permission was not granted. Check Safari settings and allow Motion & Orientation access.",
          "bad"
        );

        return;

      }

    }

    window.addEventListener(
      "devicemotion",
      handleMotionEvent
    );

    state.motionEnabled = true;
    state.demoMode = false;

    setStatus(
      ui.permissionStatus,
      "Motion sensors enabled. Move your phone and watch the live sensor feed.",
      "good"
    );

  }catch(error){

    setStatus(
      ui.permissionStatus,
      "Unable to enable motion sensors: " + error.message,
      "bad"
    );

  }

}

/* =========================================================
MOTION HANDLER
========================================================= */

function handleMotionEvent(event){

  /*
    Prefer accelerationIncludingGravity because it gives a
    stronger signal for free-fall / landing patterns.
  */

  const acceleration =
    event.accelerationIncludingGravity ||
    event.acceleration ||
    {x:0,y:0,z:0};

  const x = acceleration.x || 0;
  const y = acceleration.y || 0;
  const z = acceleration.z || 0;

  const magnitude =
    Math.sqrt(
      x * x +
      y * y +
      z * z
    );

  const now = performance.now();

  updateSampleRate(now);

  state.live = {
    x,
    y,
    z,
    magnitude
  };

  if(state.recording){

    state.samples.push({
      time:now,
      x,
      y,
      z,
      magnitude
    });

  }

}

/* =========================================================
SAMPLE RATE
========================================================= */

function updateSampleRate(now){

  if(state.lastSampleTime){

    const deltaSeconds =
      (now - state.lastSampleTime) / 1000;

    if(deltaSeconds > 0){

      const instantRate =
        1 / deltaSeconds;

      if(state.sampleRate === 0){

        state.sampleRate = instantRate;

      }else{

        state.sampleRate =
          state.sampleRate * 0.9 +
          instantRate * 0.1;

      }

    }

  }

  state.lastSampleTime = now;

}

/* =========================================================
DEMO MODE
========================================================= */

function enableDemoMode(){

  state.demoMode = true;
  state.motionEnabled = true;

  state.live = {
    x:0,
    y:0,
    z:G,
    magnitude:G
  };

  state.sampleRate = 60;

  setStatus(
    ui.permissionStatus,
    "Demo mode enabled. The app will generate simulated jump data.",
    "warn"
  );

  setStatus(
    ui.testStatus,
    "Demo mode active. Calibrate, then start assessment.",
    "warn"
  );

}

/* =========================================================
SIMULATED LIVE FEED
========================================================= */

function updateDemoLiveFeed(){

  if(!state.demoMode){
    return;
  }

  const noise =
    (Math.random() - 0.5) * 0.35;

  state.live = {
    x:noise,
    y:noise * 0.7,
    z:G + noise,
    magnitude:G + noise
  };

}

/* =========================================================
GENERATE DEMO JUMP
========================================================= */

function generateDemoJumpSamples(){

  const samples = [];

  const startTime =
    performance.now();

  const sampleRate = 60;

  const interval =
    1000 / sampleRate;

  const totalDurationMs = 5000;

  const flightDurationSeconds =
    0.38 + Math.random() * 0.18;

  const takeoffTimeMs =
    1700 + Math.random() * 300;

  const landingTimeMs =
    takeoffTimeMs +
    flightDurationSeconds * 1000;

  for(
    let t = 0;
    t <= totalDurationMs;
    t += interval
  ){

    let magnitude =
      G + (Math.random() - 0.5) * 0.45;

    /*
      Take-off impulse.
    */

    if(
      t > takeoffTimeMs - 180 &&
      t < takeoffTimeMs
    ){

      magnitude =
        G * (1.2 + Math.random() * 0.35);

    }

    /*
      Flight phase.
      Magnitude drops close to zero-force.
    */

    if(
      t >= takeoffTimeMs &&
      t <= landingTimeMs
    ){

      magnitude =
        G * (0.07 + Math.random() * 0.08);

    }

    /*
      Landing spike.
    */

    if(
      t > landingTimeMs &&
      t < landingTimeMs + 180
    ){

      magnitude =
        G * (2.0 + Math.random() * 0.9);

    }

    samples.push({
      time:startTime + t,
      x:0,
      y:0,
      z:magnitude,
      magnitude
    });

  }

  return samples;

}

/* =========================================================
LIVE UI LOOP
========================================================= */

function updateLiveInterface(){

  if(state.demoMode){
    updateDemoLiveFeed();
  }

  ui.liveX.textContent =
    formatNumber(state.live.x, 2);

  ui.liveY.textContent =
    formatNumber(state.live.y, 2);

  ui.liveZ.textContent =
    formatNumber(state.live.z, 2);

  ui.liveMagnitude.textContent =
    formatNumber(state.live.magnitude, 2);

  ui.sampleRate.textContent =
    state.sampleRate
      ? Math.round(state.sampleRate)
      : "--";

  ui.baselineValue.textContent =
    state.baseline
      ? formatNumber(state.baseline, 2)
      : "--";

  ui.attemptCounter.textContent =
    `${state.attempts.length} / 3`;

  requestAnimationFrame(updateLiveInterface);

}

/* =========================================================
INITIAL EVENT LISTENERS — SENSOR ONLY
More event listeners are added in later parts.
========================================================= */

ui.enableMotionBtn.addEventListener(
  "click",
  enableMotionSensors
);

ui.demoModeBtn.addEventListener(
  "click",
  enableDemoMode
);

/* =========================================================
START LIVE UI LOOP
========================================================= */

updateLiveInterface();

/* =========================================================
JUMPCHECK V2 — PART 3 OF 5
CALIBRATION + RECORDING + COUNTDOWN + ATTEMPT FLOW
========================================================= */

/* =========================================================
CALIBRATION
========================================================= */

async function calibrateDevice(){

  if(!state.motionEnabled){

    setStatus(
      ui.testStatus,
      "Enable motion sensors or demo mode first.",
      "warn"
    );

    return;

  }

  state.calibrating = true;

  setStatus(
    ui.testStatus,
    "Calibrating. Stand still for 3 seconds.",
    "warn"
  );

  const readings = [];

  const startTime =
    performance.now();

  while(performance.now() - startTime < 3000){

    readings.push(state.live.magnitude || G);

    await sleep(50);

  }

  const average =
    readings.reduce((sum,value) => sum + value, 0) /
    readings.length;

  const variance =
    readings.reduce(
      (sum,value) => sum + Math.pow(value - average, 2),
      0
    ) / readings.length;

  const standardDeviation =
    Math.sqrt(variance);

  state.baseline = average || G;

  state.calibrating = false;

  if(standardDeviation > 1.2 && !state.demoMode){

    setStatus(
      ui.testStatus,
      "Calibration saved, but phone movement was noisy. Tighten placement and recalibrate if needed.",
      "warn"
    );

  }else{

    setStatus(
      ui.testStatus,
      "Calibration complete. Ready to jump.",
      "good"
    );

  }

}

/* =========================================================
COUNTDOWN
========================================================= */

async function runCountdown(){

  ui.countdown.classList.remove("hidden");

  const steps = ["3","2","1","JUMP"];

  for(const step of steps){

    ui.countdown.textContent = step;

    if(step === "JUMP"){
      await sleep(450);
    }else{
      await sleep(700);
    }

  }

  ui.countdown.classList.add("hidden");

}

/* =========================================================
RECORD RAW MOTION
========================================================= */

async function recordMotionWindow(){

  state.samples = [];

  if(state.demoMode){

    state.samples = generateDemoJumpSamples();

    await sleep(600);

    return state.samples;

  }

  state.recording = true;

  await sleep(5000);

  state.recording = false;

  return state.samples;

}

/* =========================================================
SINGLE ATTEMPT FLOW
========================================================= */

async function runSingleAttempt(){

  if(!state.motionEnabled){

    setStatus(
      ui.testStatus,
      "Enable motion sensors first.",
      "warn"
    );

    return null;

  }

  if(!state.baseline){

    setStatus(
      ui.testStatus,
      "Calibrate first so the app knows your standing baseline.",
      "warn"
    );

    return null;

  }

  await runCountdown();

  setStatus(
    ui.testStatus,
    `Recording attempt ${state.currentAttempt + 1}. Jump now.`,
    "warn"
  );

  const samples =
    await recordMotionWindow();

  const analysis =
    analyseJump(samples);

  state.latestAnalysis = analysis;

  drawJumpGraph(analysis);

  if(!analysis.success){

    setStatus(
      ui.testStatus,
      "Attempt not counted: " + analysis.reason,
      "bad"
    );

    return null;

  }

  state.attempts.push(analysis);

  setStatus(
    ui.testStatus,
    `Attempt ${state.attempts.length}: ${formatNumber(analysis.heightCm,1)} cm.`,
    analysis.confidenceType
  );

  updateResults();

  return analysis;

}

/* =========================================================
ASSESSMENT FLOW
========================================================= */

async function startAssessment(){

  if(state.assessmentRunning){
    return;
  }

  if(!state.motionEnabled){

    setStatus(
      ui.testStatus,
      "Enable motion sensors or demo mode first.",
      "warn"
    );

    return;

  }

  if(!state.baseline){

    setStatus(
      ui.testStatus,
      "Calibrate before starting your assessment.",
      "warn"
    );

    return;

  }

  state.assessmentRunning = true;

  state.attempts = [];

  state.currentAttempt = 0;

  ui.resultsCard.classList.add("hidden");

  for(
    state.currentAttempt = 0;
    state.currentAttempt < 3;
    state.currentAttempt++
  ){

    await runSingleAttempt();

    if(state.currentAttempt < 2){

      setStatus(
        ui.testStatus,
        "Rest briefly. Next attempt coming up.",
        "warn"
      );

      await sleep(1800);

    }

  }

  state.assessmentRunning = false;

  if(state.attempts.length > 0){

    setStatus(
      ui.testStatus,
      "Assessment complete. Review and save your session.",
      "good"
    );

  }else{

    setStatus(
      ui.testStatus,
      "Assessment finished, but no valid jumps were detected.",
      "bad"
    );

  }

}

/* =========================================================
PART 3 EVENT LISTENERS
========================================================= */

ui.calibrateBtn.addEventListener(
  "click",
  calibrateDevice
);

ui.startAssessmentBtn.addEventListener(
  "click",
  startAssessment
);

