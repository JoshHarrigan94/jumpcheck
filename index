/* =========================================================
JUMPCHECK V2 — PART 4 OF 5
JUMP ANALYSIS + SMOOTHING + DETECTION + CONFIDENCE
========================================================= */

/* =========================================================
MOVING AVERAGE SMOOTHING
========================================================= */

function movingAverage(values, windowSize = 7){

  const smoothed = [];

  const halfWindow =
    Math.floor(windowSize / 2);

  for(let i = 0; i < values.length; i++){

    let sum = 0;
    let count = 0;

    for(
      let j = i - halfWindow;
      j <= i + halfWindow;
      j++
    ){

      if(j >= 0 && j < values.length){

        sum += values[j];
        count++;

      }

    }

    smoothed.push(sum / count);

  }

  return smoothed;

}

/* =========================================================
JUMP ANALYSIS
========================================================= */

function analyseJump(samples){

  const baseline =
    state.baseline || G;

  if(!samples || samples.length < 30){

    return {
      success:false,
      reason:"Not enough motion samples were recorded.",
      samples:samples || [],
      smooth:[],
      takeoffIndex:-1,
      landingIndex:-1,
      confidenceType:"bad"
    };

  }

  const magnitudes =
    samples.map(sample => sample.magnitude);

  const smooth =
    movingAverage(magnitudes, 7);

  /*
    These thresholds are deliberately conservative.

    Flight:
    phone acceleration magnitude drops far below standing baseline.

    Landing:
    phone acceleration magnitude spikes clearly above standing baseline.
  */

  const flightThreshold =
    baseline * 0.45;

  const landingThreshold =
    baseline * 1.6;

  const minimumFlightSeconds =
    0.22;

  const maximumFlightSeconds =
    0.90;

  const sampleRate =
    state.sampleRate || 60;

  const sustainedFlightSamples =
    Math.max(
      4,
      Math.round(sampleRate * 0.06)
    );

  let takeoffIndex = -1;
  let landingIndex = -1;

  /* =======================================================
  FIND TAKE-OFF
  ======================================================= */

  for(
    let i = 4;
    i < smooth.length - sustainedFlightSamples;
    i++
  ){

    let sustainedLowForce = true;

    for(
      let j = 0;
      j < sustainedFlightSamples;
      j++
    ){

      if(smooth[i + j] > flightThreshold){

        sustainedLowForce = false;
        break;

      }

    }

    if(sustainedLowForce){

      takeoffIndex = i;
      break;

    }

  }

  if(takeoffIndex === -1){

    return {
      success:false,
      reason:"No clear flight phase detected. Try tightening the phone strap and jumping more cleanly.",
      samples,
      smooth,
      takeoffIndex,
      landingIndex,
      confidenceType:"bad"
    };

  }

  /* =======================================================
  FIND LANDING
  ======================================================= */

  for(
    let i = takeoffIndex + sustainedFlightSamples;
    i < smooth.length;
    i++
  ){

    const flightSeconds =
      (samples[i].time - samples[takeoffIndex].time) /
      1000;

    if(flightSeconds > maximumFlightSeconds){
      break;
    }

    if(
      flightSeconds >= minimumFlightSeconds &&
      smooth[i] > landingThreshold
    ){

      landingIndex = i;
      break;

    }

  }

  if(landingIndex === -1){

    return {
      success:false,
      reason:"Take-off was detected, but landing spike was unclear.",
      samples,
      smooth,
      takeoffIndex,
      landingIndex,
      confidenceType:"bad"
    };

  }

  /* =======================================================
  CALCULATE FLIGHT TIME + HEIGHT
  ======================================================= */

  const flightTimeSeconds =
    (samples[landingIndex].time - samples[takeoffIndex].time) /
    1000;

  const heightMetres =
    G * flightTimeSeconds * flightTimeSeconds / 8;

  const heightCm =
    heightMetres * 100;

  const landingWindow =
    smooth.slice(
      landingIndex,
      Math.min(smooth.length, landingIndex + 20)
    );

  const peakLandingMagnitude =
    Math.max(...landingWindow);

  /* =======================================================
  CONFIDENCE SCORING
  ======================================================= */

  let confidence =
    "High confidence";

  let confidenceType =
    "good";

  const flags = [];

  if(flightTimeSeconds < minimumFlightSeconds + 0.04){

    confidence =
      "Medium confidence";

    confidenceType =
      "warn";

    flags.push("short flight window");

  }

  if(flightTimeSeconds > maximumFlightSeconds - 0.05){

    confidence =
      "Medium confidence";

    confidenceType =
      "warn";

    flags.push("long flight window");

  }

  if(heightCm < 5 || heightCm > 90){

    confidence =
      "Low confidence";

    confidenceType =
      "bad";

    flags.push("height outside expected range");

  }

  if(state.sampleRate && state.sampleRate < 25 && !state.demoMode){

    confidence =
      "Low confidence";

    confidenceType =
      "bad";

    flags.push("low sensor sample rate");

  }

  if(peakLandingMagnitude < baseline * 1.4){

    confidence =
      "Medium confidence";

    confidenceType =
      confidenceType === "bad" ? "bad" : "warn";

    flags.push("weak landing spike");

  }

  return {
    success:true,

    samples,
    smooth,

    takeoffIndex,
    landingIndex,

    flightTimeSeconds,
    heightCm,

    peakLandingMagnitude,

    confidence,
    confidenceType,

    flags
  };

}

/* =========================================================
RESULT CALCULATIONS
========================================================= */

function calculateAssessmentSummary(){

  const heights =
    state.attempts.map(attempt => attempt.heightCm);

  if(!heights.length){
    return null;
  }

  const best =
    Math.max(...heights);

  const worst =
    Math.min(...heights);

  const average =
    heights.reduce((sum,value) => sum + value, 0) /
    heights.length;

  const dropoff =
    best > 0
      ? ((best - worst) / best) * 100
      : 0;

  return {
    heights,
    best,
    worst,
    average,
    dropoff
  };

}

/* =========================================================
HISTORICAL BEST
========================================================= */

function getHistoricalBest(){

  const bests =
    state.history
      .map(session => session.best)
      .filter(value => Number.isFinite(value));

  if(!bests.length){
    return null;
  }

  return Math.max(...bests);

}

/* =========================================================
READINESS INTERPRETATION
========================================================= */

function getReadiness(bestJump){

  const historicalBest =
    getHistoricalBest();

  if(!historicalBest){

    return {
      label:"First baseline",
      type:"warn"
    };

  }

  const percentageDown =
    ((historicalBest - bestJump) / historicalBest) * 100;

  if(percentageDown <= 5){

    return {
      label:"Green: within 5% of best",
      type:"good"
    };

  }

  if(percentageDown <= 10){

    return {
      label:"Amber: 5–10% down",
      type:"warn"
    };

  }

  return {
    label:"Red: >10% down",
    type:"bad"
  };

}

/* =========================================================
UPDATE RESULTS UI
========================================================= */

function updateResults(){

  const summary =
    calculateAssessmentSummary();

  if(!summary){
    return;
  }

  ui.resultsCard.classList.remove("hidden");

  ui.bestJumpValue.textContent =
    formatNumber(summary.best, 1);

  ui.bestMetric.textContent =
    formatNumber(summary.best, 1) + " cm";

  ui.averageMetric.textContent =
    formatNumber(summary.average, 1) + " cm";

  ui.dropoffMetric.textContent =
    formatNumber(summary.dropoff, 1) + "%";

  const hasLowConfidence =
    state.attempts.some(
      attempt => attempt.confidenceType === "bad"
    );

  const hasMediumConfidence =
    state.attempts.some(
      attempt => attempt.confidenceType === "warn"
    );

  if(hasLowConfidence){

    setPill(
      ui.confidencePill,
      "Low confidence",
      "bad"
    );

  }else if(hasMediumConfidence){

    setPill(
      ui.confidencePill,
      "Medium confidence",
      "warn"
    );

  }else{

    setPill(
      ui.confidencePill,
      "High confidence",
      "good"
    );

  }

  const readiness =
    getReadiness(summary.best);

  setPill(
    ui.readinessPill,
    readiness.label,
    readiness.type
  );

  ui.attemptPills.innerHTML =
    state.attempts
      .map((attempt,index) => {

        return `
          <span class="pill ${attempt.confidenceType}">
            J${index + 1}: ${formatNumber(attempt.heightCm,1)} cm
          </span>
        `;

      })
      .join("");

}

